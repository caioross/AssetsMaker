{
  "_comment": "Probe minimal — usado para testar se o DNA está produzindo resultados coerentes. Sem ControlNet, sem IP-Adapter, só SD 1.5 + LoRAs. Você passa o prompt 'um guerreiro genérico' e vê se sai dentro do estilo.",

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "@@CHECKPOINT@@" }
  },

  "2": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "@@VAE@@" }
  },

  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@PROMPT@@", "clip": ["1", 1] }
  },

  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@NEGATIVE@@", "clip": ["1", 1] }
  },

  "30": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "@@WIDTH@@",
      "height": "@@HEIGHT@@",
      "batch_size": 1
    }
  },

  "31": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["30", 0],
      "seed": "@@SEED@@",
      "steps": "@@STEPS@@",
      "cfg": "@@CFG@@",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },

  "40": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["31", 0], "vae": ["2", 0] }
  },

  "50": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["40", 0],
      "filename_prefix": "dna_probe"
    }
  }
}
