{
  "_comment": "Building isometrico SD 1.5 — ControlNet Lineart para silhueta arquitetural precisa, sem IP-Adapter (prédios não precisam de identidade entre frames).",

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "@@CHECKPOINT@@" }
  },

  "2": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "@@VAE@@" }
  },

  "3": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "@@LORA_0_NAME@@",
      "strength_model": "@@LORA_0_MODEL_WEIGHT@@",
      "strength_clip": "@@LORA_0_CLIP_WEIGHT@@"
    }
  },

  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@PROMPT@@", "clip": ["3", 1] }
  },

  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@NEGATIVE@@", "clip": ["3", 1] }
  },

  "20": {
    "class_type": "LoadImage",
    "inputs": { "image": "@@CONTROLNET_INPUT@@" }
  },

  "21": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "control_v11p_sd15_lineart.pth" }
  },

  "22": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["6", 0],
      "control_net": ["21", 0],
      "image": ["20", 0],
      "strength": "@@CONTROLNET_STRENGTH@@",
      "start_percent": 0.0,
      "end_percent": 0.9
    }
  },

  "30": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "@@WIDTH@@",
      "height": "@@HEIGHT@@",
      "batch_size": 1
    }
  },

  "31": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["3", 0],
      "positive": ["22", 0],
      "negative": ["22", 1],
      "latent_image": ["30", 0],
      "seed": "@@SEED@@",
      "steps": "@@STEPS@@",
      "cfg": "@@CFG@@",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },

  "40": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["31", 0], "vae": ["2", 0] }
  },

  "50": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["40", 0],
      "filename_prefix": "asset_building"
    }
  }
}
