{
  "_comment": "Terrain tile SD 1.5 — geração quadrada tileable (deve ser pós-processada para garantir tile-safe se necessário).",

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "@@CHECKPOINT@@" }
  },

  "2": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "@@VAE@@" }
  },

  "3": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "@@LORA_0_NAME@@",
      "strength_model": "@@LORA_0_MODEL_WEIGHT@@",
      "strength_clip": "@@LORA_0_CLIP_WEIGHT@@"
    }
  },

  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@PROMPT@@", "clip": ["3", 1] }
  },

  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@NEGATIVE@@", "clip": ["3", 1] }
  },

  "30": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "@@WIDTH@@",
      "height": "@@HEIGHT@@",
      "batch_size": 1
    }
  },

  "31": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["3", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["30", 0],
      "seed": "@@SEED@@",
      "steps": "@@STEPS@@",
      "cfg": "@@CFG@@",
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },

  "40": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["31", 0], "vae": ["2", 0] }
  },

  "50": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["40", 0],
      "filename_prefix": "asset_terrain"
    }
  }
}
