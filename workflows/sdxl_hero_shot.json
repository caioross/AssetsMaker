{
  "_comment": "SDXL Lightning hero shot — qualidade premium para UI portraits / loading screens. Mais lento, lowvram-friendly.",

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "@@CHECKPOINT@@" }
  },

  "2": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "@@VAE@@" }
  },

  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@PROMPT@@", "clip": ["1", 1] }
  },

  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@NEGATIVE@@", "clip": ["1", 1] }
  },

  "30": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "@@WIDTH@@",
      "height": "@@HEIGHT@@",
      "batch_size": 1
    }
  },

  "31": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["30", 0],
      "seed": "@@SEED@@",
      "steps": 8,
      "cfg": 2.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },

  "40": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["31", 0], "vae": ["2", 0] }
  },

  "50": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["40", 0],
      "filename_prefix": "asset_hero"
    }
  }
}
