{
  "_comment": "Variant generation — usado para gerar frames de animação ou variações de uma mesma unidade. Master sheet alimenta IP-Adapter com peso alto para consistência. Prompt varia (idle vs walk vs attack).",

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "@@CHECKPOINT@@" }
  },

  "2": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "@@VAE@@" }
  },

  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@PROMPT@@", "clip": ["1", 1] }
  },

  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "@@NEGATIVE@@", "clip": ["1", 1] }
  },

  "10": {
    "class_type": "LoadImage",
    "inputs": { "image": "@@IPADAPTER_REFERENCE@@" }
  },

  "11": {
    "class_type": "CLIPVisionLoader",
    "inputs": { "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors" }
  },

  "12": {
    "class_type": "IPAdapterModelLoader",
    "inputs": { "ipadapter_file": "ip-adapter-plus_sd15.safetensors" }
  },

  "13": {
    "class_type": "IPAdapter",
    "inputs": {
      "model": ["1", 0],
      "ipadapter": ["12", 0],
      "image": ["10", 0],
      "clip_vision": ["11", 0],
      "weight": "@@IPADAPTER_WEIGHT@@",
      "weight_type": "strong",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },

  "30": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "@@WIDTH@@",
      "height": "@@HEIGHT@@",
      "batch_size": 1
    }
  },

  "31": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["13", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["30", 0],
      "seed": "@@SEED@@",
      "steps": "@@STEPS@@",
      "cfg": "@@CFG@@",
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },

  "40": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["31", 0], "vae": ["2", 0] }
  },

  "50": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["40", 0],
      "filename_prefix": "asset_variant"
    }
  }
}
